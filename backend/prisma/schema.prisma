generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  
  draftPlans DraftPlan[]
}

model DraftPlan {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  synergyNote String?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  heroes       ListHero[]
  enemyThreats EnemyThreat[]
  itemTimings  ItemTiming[]
}

enum HeroListType {
  BAN
  PREFERRED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

model ListHero {
  id          Int          @id @default(autoincrement())
  draftPlanId Int
  heroId      Int
  type        HeroListType
  role        String?
  priority    Priority?
  note        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  draftPlan DraftPlan @relation(fields: [draftPlanId], references: [id], onDelete: Cascade)
}

model EnemyThreat {
  id          Int      @id @default(autoincrement())
  draftPlanId Int
  heroId      Int
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  draftPlan DraftPlan @relation(fields: [draftPlanId], references: [id], onDelete: Cascade)
}

model ItemTiming {
  id          Int      @id @default(autoincrement())
  draftPlanId Int
  timing      String
  explanation String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  draftPlan DraftPlan @relation(fields: [draftPlanId], references: [id], onDelete: Cascade)
}

model HeroCache {
  id            Int      @id
  name          String
  localizedName String
  primaryAttr   String
  attackType    String
  roles         String[]
  legs          Int
  imageUrl      String?
  updatedAt     DateTime @updatedAt
}

model JobQueue {
  id          Int      @id @default(autoincrement())
  status      String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  type        String   // "ANALYZE_SYNERGY"
  payload     String   // JSON stringified payload
  result      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

